---
import '../styles/global.css';

interface Props {
  title?: string;
  bodyClass?: string;
}

const { title = 'Judy Rosenthal', bodyClass = 'page-content' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;600&display=swap">
  <meta name="description" content="In loving memory of Judy Rosenthal — artist, author, mother, and friend.">
</head>
<body class={bodyClass}>
  <slot />
</body>
</html>
