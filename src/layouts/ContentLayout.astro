---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SectionHero from '../components/SectionHero.astro';

interface Props {
  frontmatter?: {
    title?: string;
    hero?: string;
    heroHeight?: string;
    heroPosition?: string;
    albumDir?: string;
    collection?: boolean;
    heroLightbox?: boolean;
  };
  title?: string;
  showBreadcrumbs?: boolean;
  /** When set (family pages), the dev tools show "Edit Person" instead of "Edit Content". */
  personSlug?: string;
}

const { frontmatter, showBreadcrumbs = true, personSlug } = Astro.props;
const title = frontmatter?.title ?? Astro.props.title ?? '';
const hero = frontmatter?.hero;
const heroHeight = frontmatter?.heroHeight ?? '250px';
const heroPosition = frontmatter?.heroPosition ?? 'center';
const heroLightbox = frontmatter?.heroLightbox ?? false;
const albumDir = frontmatter?.albumDir;

const isCollection = frontmatter?.collection ?? false;
const pageTitle = `${title} | Judy Rosenthal`;
const bodyClass = isCollection ? 'page-content page-collection' : 'page-content';
---

<BaseLayout title={pageTitle} bodyClass={bodyClass}>

  <Header />
  <hr class="content-rule" />
  <main class="content-body">
    {hero && <SectionHero hero={hero} heroHeight={heroHeight} heroPosition={heroPosition} alt={title} lightbox={heroLightbox} />}

    {showBreadcrumbs && <Breadcrumbs pathname={Astro.url.pathname} />}
    <slot />
  </main>
  <Footer />
  
  {import.meta.env.DEV && (
    <div class="dev-tools">
      {/* Both states are rendered server-side, then revealed by the script below
          based on the login state (read client-side, since content pages are
          prerendered and can't read cookies in their frontmatter). */}
      <div id="dev-tools-authed" class="dev-tools-group" hidden>
        {personSlug ? (
          <a href={`/edit-person?slug=${personSlug}`}>👤 Edit Person</a>
        ) : (
          <>
            <a href={`/edit?page=${Astro.url.pathname}`}>✏️ Edit Content</a>
            {albumDir && <a href={`/manage-photos?album=${albumDir}&page=${Astro.url.pathname}`}>📸 Manage Photos</a>}
          </>
        )}
        <button type="button" id="dev-logout">🚪 Log out</button>
      </div>
      <a
        id="dev-tools-login"
        class="dev-tools-group"
        href={`/login?next=${encodeURIComponent(Astro.url.pathname)}`}
        hidden
      >🔒 Log in</a>
    </div>
  )}

  {import.meta.env.DEV && (
    <script>
      document.getElementById('dev-logout')?.addEventListener('click', async () => {
        await fetch('/api/auth/logout', { method: 'POST' });
        window.location.reload();
      });

      // Ask the server who's logged in (reads the httpOnly session cookie, which
      // prerendered pages can't see in their own frontmatter), then reveal the
      // matching toolbar state.
      fetch('/api/auth/me')
        .then((r) => r.json())
        .then((data) => {
          if (data && data.user) {
            document.getElementById('dev-tools-authed')?.removeAttribute('hidden');
            const btn = document.getElementById('dev-logout');
            if (btn) btn.title = 'Logged in as ' + data.user;
          } else {
            document.getElementById('dev-tools-login')?.removeAttribute('hidden');
          }
        })
        .catch(() => {
          document.getElementById('dev-tools-login')?.removeAttribute('hidden');
        });
    </script>
  )}
</BaseLayout>
