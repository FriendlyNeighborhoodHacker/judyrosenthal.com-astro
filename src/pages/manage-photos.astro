---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = false;

// DEV-ONLY page. In production this redirects home (and never gets built).
if (!import.meta.env.DEV) {
  return Astro.redirect('/');
}

const album = Astro.url.searchParams.get('album') ?? '';
const page = Astro.url.searchParams.get('page') ?? '';
---

<BaseLayout title="Manage Photos" bodyClass="page-manage">
  <main class="manager">
    <header class="manager-bar">
      <h1>Manage Photos</h1>
      <div class="manager-meta">
        <span>Album: <code id="album-path">{album}</code></span>
        {page && <a class="manager-view" href={page} target="_blank" rel="noopener">View page ↗</a>}
      </div>
    </header>

    <p id="manager-status" class="manager-status" role="status"></p>

    <section class="uploader">
      <label class="upload-label">
        Upload photos
        <input type="file" id="file-input" accept="image/*" multiple />
      </label>
      <button type="button" id="upload-btn">Upload</button>
    </section>

    <p class="hint">Drag the ☰ handle to reorder and edit captions, then click <strong>Save changes</strong>. Uploads and deletes apply immediately.</p>

    <table class="photo-table">
      <tbody id="photo-list"></tbody>
    </table>

    <div class="save-bar">
      <button type="button" id="save-btn" disabled>Save changes</button>
      <span id="save-state" class="save-state">All changes saved</span>
    </div>
  </main>
</BaseLayout>

<style>
  .manager { max-width: 820px; margin: 0 auto; padding: 2rem 1.5rem 4rem; font-family: system-ui, sans-serif; }
  .manager-bar { display: flex; align-items: baseline; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; border-bottom: 1px solid #ddd; padding-bottom: 0.75rem; margin-bottom: 1rem; }
  .manager-bar h1 { margin: 0; font-size: 1.4rem; }
  .manager-meta { font-size: 0.85rem; color: #555; display: flex; gap: 1rem; }
  .manager-meta code { background: #f3f3f3; padding: 0.1rem 0.3rem; border-radius: 3px; }
  .manager-view { color: #1a5; text-decoration: none; }
  .manager-status { min-height: 1.2rem; font-size: 0.9rem; }
  .manager-status.ok { color: #1a7f37; }
  .manager-status.err { color: #c0392b; }
  .uploader { display: flex; align-items: center; gap: 0.75rem; margin: 0.5rem 0 1rem; }
  .upload-label { font-size: 0.9rem; display: flex; flex-direction: column; gap: 0.3rem; }
  .hint { font-size: 0.8rem; color: #777; margin: 0.25rem 0 1rem; }
  button { padding: 0.5rem 1.1rem; border: none; border-radius: 6px; background: #1a5; color: white; font-size: 0.9rem; cursor: pointer; }
  button:disabled { opacity: 0.6; cursor: default; }
  .save-bar { position: sticky; bottom: 0; display: flex; align-items: center; gap: 0.85rem; padding: 0.85rem 0; margin-top: 1rem; background: #fff; border-top: 1px solid #e2e2e2; }
  #save-btn { font-size: 0.95rem; padding: 0.6rem 1.4rem; }
  .save-state { font-size: 0.85rem; color: #999; }
  .save-state.dirty { color: #c0392b; font-weight: 600; }
</style>

<!--
  The photo rows are built in JS (document.createElement), so Astro's scoped
  styles (which key off a build-time data-astro-* attribute) never reach them.
  These rules are global but namespaced under .page-manage (this page's body
  class) so they don't leak to the rest of the site.
-->
<style is:global>
  .page-manage .photo-table { width: 100%; border-collapse: collapse; }
  .page-manage .photo-row { background: #fff; }
  .page-manage .photo-row > td { padding: 0.65rem 0.5rem; border-bottom: 1px solid #ececec; vertical-align: middle; }
  .page-manage .photo-row.dragging { opacity: 0.45; }
  .page-manage .photo-row.drag-over > td { box-shadow: inset 0 2px 0 #1a5; }

  .page-manage .cell-handle { width: 1.75rem; text-align: center; color: #aaa; cursor: grab; font-size: 1.25rem; user-select: none; }
  .page-manage .cell-img { width: 170px; }
  .page-manage .photo-thumb { display: block; width: 150px; height: 110px; object-fit: cover; border-radius: 6px; background: #f0f0f0; }

  .page-manage .cell-caption { width: 100%; }
  .page-manage .photo-name { font-size: 0.72rem; color: #999; margin-bottom: 0.35rem; word-break: break-all; }
  .page-manage .photo-caption {
    width: 100%;
    padding: 0.55rem 0.7rem;
    border: 1px solid #b8b8b8;
    border-radius: 6px;
    font-size: 0.95rem;
    background: #fcfcfc;
    box-sizing: border-box;
  }
  .page-manage .photo-caption::placeholder { color: #b0b0b0; }
  .page-manage .photo-caption:focus {
    outline: none;
    border-color: #1a5;
    background: #fff;
    box-shadow: 0 0 0 2px rgba(26, 170, 85, 0.18);
  }

  .page-manage .cell-actions { width: 1%; white-space: nowrap; text-align: right; }
  .page-manage .photo-del { padding: 0.45rem 0.9rem; border: none; border-radius: 6px; background: #c0392b; color: #fff; font-size: 0.85rem; cursor: pointer; }
</style>

<script>
  const album = document.getElementById('album-path')?.textContent?.trim() ?? '';
  const statusEl = document.getElementById('manager-status') as HTMLElement;
  const listEl = document.getElementById('photo-list') as HTMLTableSectionElement;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const uploadBtn = document.getElementById('upload-btn') as HTMLButtonElement;
  const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
  const saveState = document.getElementById('save-state') as HTMLElement;

  type Photo = { filename: string; caption: string };
  let photos: Photo[] = [];
  let dirty = false;

  function setStatus(msg: string, kind: '' | 'ok' | 'err' = '') {
    statusEl.textContent = msg;
    statusEl.className = 'manager-status' + (kind ? ' ' + kind : '');
  }

  /** Track unsaved caption/order edits and reflect them in the Save bar. */
  function setDirty(d: boolean) {
    dirty = d;
    saveBtn.disabled = !d;
    saveState.textContent = d ? 'Unsaved changes' : 'All changes saved';
    saveState.classList.toggle('dirty', d);
  }

  async function load() {
    setStatus('Loading…');
    try {
      const res = await fetch(`/api/photos/list?album=${encodeURIComponent(album)}`);
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed to load');
      photos = data.photos;
      render();
      setDirty(false);
      setStatus(`${photos.length} photo(s)`, 'ok');
    } catch (err) {
      setStatus(String(err), 'err');
    }
  }

  function render() {
    listEl.innerHTML = '';
    photos.forEach((photo, index) => {
      const tr = document.createElement('tr');
      tr.className = 'photo-row';
      tr.draggable = true;
      tr.dataset.index = String(index);

      const handleCell = document.createElement('td');
      handleCell.className = 'cell-handle';
      handleCell.textContent = '☰';

      const imgCell = document.createElement('td');
      imgCell.className = 'cell-img';
      const img = document.createElement('img');
      img.className = 'photo-thumb';
      img.loading = 'lazy';
      img.alt = photo.caption || photo.filename;
      img.src = `/api/photos/thumb?album=${encodeURIComponent(album)}&file=${encodeURIComponent(photo.filename)}`;
      imgCell.append(img);

      const captionCell = document.createElement('td');
      captionCell.className = 'cell-caption';

      const name = document.createElement('div');
      name.className = 'photo-name';
      name.textContent = photo.filename;

      const caption = document.createElement('input');
      caption.className = 'photo-caption';
      caption.type = 'text';
      caption.placeholder = 'Caption…';
      caption.value = photo.caption;
      caption.addEventListener('input', () => {
        photos[index].caption = caption.value;
        setDirty(true);
      });

      captionCell.append(name, caption);

      const actionsCell = document.createElement('td');
      actionsCell.className = 'cell-actions';
      const del = document.createElement('button');
      del.className = 'photo-del';
      del.textContent = 'Delete';
      del.addEventListener('click', () => deletePhoto(photo.filename));
      actionsCell.append(del);

      tr.append(handleCell, imgCell, captionCell, actionsCell);
      attachDrag(tr);
      listEl.append(tr);
    });
  }

  /* Drag-and-drop reordering */
  let dragIndex = -1;
  function attachDrag(row: HTMLTableRowElement) {
    row.addEventListener('dragstart', () => {
      dragIndex = Number(row.dataset.index);
      row.classList.add('dragging');
    });
    row.addEventListener('dragend', () => row.classList.remove('dragging'));
    row.addEventListener('dragover', (e) => { e.preventDefault(); row.classList.add('drag-over'); });
    row.addEventListener('dragleave', () => row.classList.remove('drag-over'));
    row.addEventListener('drop', (e) => {
      e.preventDefault();
      row.classList.remove('drag-over');
      const dropIndex = Number(row.dataset.index);
      if (dragIndex === -1 || dragIndex === dropIndex) return;
      const [moved] = photos.splice(dragIndex, 1);
      photos.splice(dropIndex, 0, moved);
      dragIndex = -1;
      render();
      setDirty(true);
    });
  }

  async function saveMeta() {
    const order = photos.map((p) => p.filename);
    const descriptions: Record<string, string> = {};
    photos.forEach((p) => { if (p.caption) descriptions[p.filename] = p.caption; });
    saveBtn.disabled = true;
    setStatus('Saving…');
    try {
      const res = await fetch('/api/photos/save-meta', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ album, order, descriptions }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Save failed');
      setStatus('Saved ✓', 'ok');
      setDirty(false);
    } catch (err) {
      setStatus(String(err), 'err');
      setDirty(true); // keep the unsaved state and re-enable the button to retry
    }
  }

  async function deletePhoto(filename: string) {
    if (!confirm(`Delete ${filename}? This removes the file from disk.`)) return;
    setStatus('Deleting…');
    try {
      const res = await fetch('/api/photos/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ album, filename }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Delete failed');
      photos = photos.filter((p) => p.filename !== filename);
      render();
      setStatus('Deleted ✓', 'ok');
    } catch (err) {
      setStatus(String(err), 'err');
    }
  }

  uploadBtn.addEventListener('click', async () => {
    if (!fileInput.files || fileInput.files.length === 0) {
      setStatus('Choose file(s) first', 'err');
      return;
    }
    const form = new FormData();
    form.set('album', album);
    Array.from(fileInput.files).forEach((f) => form.append('files', f));
    uploadBtn.disabled = true;
    setStatus('Uploading…');
    try {
      const res = await fetch('/api/photos/upload', { method: 'POST', body: form });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Upload failed');
      fileInput.value = '';
      // Append the saved files in memory (the upload endpoint already persisted
      // them and their order), preserving any unsaved caption/reorder edits
      // rather than reloading and discarding them.
      (data.saved as string[]).forEach((fn) => {
        if (!photos.some((p) => p.filename === fn)) photos.push({ filename: fn, caption: '' });
      });
      render();
      setStatus(`Uploaded ${data.saved.length} file(s) ✓`, 'ok');
    } catch (err) {
      setStatus(String(err), 'err');
    } finally {
      uploadBtn.disabled = false;
    }
  });

  saveBtn.addEventListener('click', () => { if (dirty) saveMeta(); });

  // Warn before leaving with unsaved caption/order edits.
  window.addEventListener('beforeunload', (e) => {
    if (dirty) {
      e.preventDefault();
      e.returnValue = '';
    }
  });

  load();
</script>
