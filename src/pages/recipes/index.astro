---
import { Image } from 'astro:assets';
import fs from 'node:fs/promises';
import path from 'node:path';
import { createMarkdownProcessor } from '@astrojs/markdown-remark';
import ContentLayout from '../../layouts/ContentLayout.astro';
import RecipeModal from '../../components/RecipeModal.astro';

/* ---------- Title helper (same convention as the collection pages) ---------- */
function smartTitleCase(str: string) {
  const smallWords = [
    'a', 'an', 'and', 'as', 'at', 'but', 'by', 'for',
    'in', 'nor', 'of', 'on', 'or', 'per', 'the', 'to', 'vs', 'via',
  ];
  return str
    .toLowerCase()
    .split(' ')
    .map((word, index) =>
      index === 0 || !smallWords.includes(word)
        ? word.charAt(0).toUpperCase() + word.slice(1)
        : word
    )
    .join(' ');
}

/* Derive the display title from the image filename, exactly like the paintings:
   strip extension, replace underscores with spaces, smart title-case. */
function titleFromFilename(filename: string) {
  let name = filename.replace(/\.[^.]+$/, '');
  name = name.replace(/_/g, ' ');
  return smartTitleCase(name);
}

const slugify = (s: string) =>
  s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');

/* ---------- Load the recipe images ---------- */
const imageGlob = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/recipes/*.{jpeg,jpg,png,gif,webp}'
);

/* ---------- Parse recipes.txt into sections ---------- */
const txtPath = path.join(
  process.cwd(),
  'src', 'assets', 'images', 'recipes', 'recipes.txt'
);
const raw = await fs.readFile(txtPath, 'utf-8');

// Sections are separated by lines made up of dashes (e.g. "-----").
const rawSections = raw
  .split(/^\s*-{3,}\s*$/m)
  .map((s) => s.trim())
  .filter(Boolean);

/* Map each image (by filename keyword) to the recipe section that mentions it.
   We score each section by how many of the image's keywords appear in it. */
function keywordsFor(filename: string): string[] {
  const base = filename.replace(/\.[^.]+$/, '');
  return base.split('_').filter(Boolean);
}

function scoreSection(section: string, keywords: string[]): number {
  const lower = section.toLowerCase();
  // Only look at the first ~400 chars (heading + intro) so body mentions
  // (e.g. asparagus referenced inside the salmon recipe) don't mislead us.
  const head = lower.slice(0, 400);
  let score = 0;
  for (const kw of keywords) {
    if (head.includes(kw.toLowerCase())) score += 2;
    else if (lower.includes(kw.toLowerCase())) score += 1;
  }
  return score;
}

const processor = await createMarkdownProcessor({});

const imageEntries = Object.entries(imageGlob).sort(([a], [b]) =>
  a.localeCompare(b)
);

const usedSections = new Set<number>();
type Recipe = {
  slug: string;
  title: string;
  filename: string;
  mod: () => Promise<{ default: ImageMetadata }>;
  html: string;
};

const recipes: Recipe[] = [];

for (const [imgPath, mod] of imageEntries) {
  const filename = imgPath.split('/').pop() || '';
  const title = titleFromFilename(filename);
  const keywords = keywordsFor(filename);

  // Find the best-matching, not-yet-used section.
  let bestIdx = -1;
  let bestScore = 0;
  rawSections.forEach((section, idx) => {
    if (usedSections.has(idx)) return;
    const score = scoreSection(section, keywords);
    if (score > bestScore) {
      bestScore = score;
      bestIdx = idx;
    }
  });

  let html = '';
  if (bestIdx !== -1) {
    usedSections.add(bestIdx);
    // Drop the section's first non-empty line if it's just a plain label
    // (e.g. "Cabbage Salad") so it doesn't duplicate the modal title; keep
    // markdown headings (## ...) since they read nicely.
    let lines = rawSections[bestIdx].split('\n');
    const firstContentIdx = lines.findIndex((l) => l.trim() !== '');
    if (firstContentIdx !== -1) {
      const first = lines[firstContentIdx].trim();
      if (!first.startsWith('#') && first.split(' ').length <= 6) {
        lines.splice(firstContentIdx, 1);
      }
    }

    // Clean up bare label prefixes like "Description:" / "Photo:" and drop
    // any now-empty "Photo:" lines that have no following text.
    lines = lines
      .map((l) => l.replace(/^\s*(Description|Photo)\s*:\s*/i, ''))
      .filter((l, i, arr) => {
        // Remove a leftover empty line that was only a "Photo:" label.
        return true;
      });

    const md = lines.join('\n').trim();
    const rendered = await processor.render(md);
    html = rendered.code;
  }

  recipes.push({
    slug: slugify(title),
    title,
    filename,
    mod,
    html,
  });
}

const frontmatter = {
  title: 'Recipes',
  hero: 'images/recipes/hero.jpg',
  heroPosition: 'center',
  heroHeight: '350px',
};
---

<ContentLayout frontmatter={frontmatter}>
  <p class="recipes-intro">
    Judy Rosenthal was a prolific baker that poured her love and time into always
    having on hand treats for the communities and people around her to take when
    needed. These were a few of her favorites! 💕
  </p>

  <div class="photo-grid recipe-grid">
    {recipes.map(async (recipe) => {
      const image = await recipe.mod();
      return (
        <div
          class="photo-grid-item recipe-grid-item"
          data-slug={recipe.slug}
          data-title={recipe.title}
        >
          <Image
            src={image.default}
            alt={recipe.title}
            widths={[350, 1200]}
            sizes="(max-width: 768px) 50vw, 350px"
            format="webp"
            loading="lazy"
          />
          <span class="recipe-grid-label">{recipe.title}</span>
        </div>
      );
    })}
  </div>

  {/* Hidden recipe content, read by the modal script. */}
  <div class="recipe-data-store" hidden>
    {recipes.map((recipe) => (
      <div id={`recipe-data-${recipe.slug}`} set:html={recipe.html} />
    ))}
  </div>

  <RecipeModal />
</ContentLayout>
