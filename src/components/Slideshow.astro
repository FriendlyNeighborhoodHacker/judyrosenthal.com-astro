---
import type { Slide } from '../data/slides';
import { getImage } from 'astro:assets';

interface Props {
  /** The slides to display. */
  slides: Slide[];
  /** Image sub-directory under src/assets/images (e.g. 'homepage' or 'art'). */
  imageDir: string;
}

const { slides, imageDir } = Astro.props;

// Glob every image so a single component can resolve whatever a slide uses
// (single `image`, or dual `landscape`/`portrait`).
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/**/*.*');

async function resolve(path?: string): Promise<string | undefined> {
  if (!path) return undefined;
  const full = `/src/assets/${path}`;
  const mod = images[full];
  if (!mod) return full;
  const imported = await mod();
  const optimized = await getImage({ src: imported.default, width: 1920, format: 'webp' });
  return optimized.src;
}

const resolvedSlides = await Promise.all(
  slides.map(async (slide) => {
    const [imageUrl, landscapeUrl, portraitUrl] = await Promise.all([
      resolve(slide.image),
      resolve(slide.landscape),
      resolve(slide.portrait),
    ]);
    const dual = Boolean(slide.landscape || slide.portrait);
    // Build a CSS inline style string for the slide background.
    let style = `background-color: ${slide.sideColor || '#000'};`;
    if (dual) {
      style += ` --bg-landscape: url('${landscapeUrl}'); --bg-portrait: url('${portraitUrl || landscapeUrl}');`;
    } else if (imageUrl) {
      style += ` background-image: url('${imageUrl}');`;
    }
    // Fallback crumbs from `title` if `crumbs` wasn't supplied.
    const crumbs = slide.crumbs && slide.crumbs.length
      ? slide.crumbs
      : (slide.title ? [{ label: slide.title }] : []);
    return { ...slide, dual, style, crumbs };
  })
);

// First slide drives the initial overlay render (so it's correct before JS runs).
const first = resolvedSlides[0];
function renderCrumbs(crumbs: { label: string; href?: string }[]) {
  return crumbs;
}
---

<div class="slideshow-wrapper">
  <div class="slideshow" id="slideshow" data-image-dir={imageDir}>
    {resolvedSlides.map((slide, index) => (
      <div
        class={`slide${slide.dual ? ' art-slide' : ''}${index === 0 ? ' active' : ''}`}
        data-link={slide.link}
        data-menu-color={slide.menuColor}
        data-wide-mode={slide.wideMode || 'cover'}
        data-shadow-color={slide.shadowColor || ''}
        data-crumbs={JSON.stringify(slide.crumbs)}
        data-title-bg={slide.titleBackground || ''}
        data-title-color={slide.titleColor || ''}
        data-title-style={slide.titleStyle || 'breadcrumb'}
        style={slide.style}
      />
    ))}

    <div
      class={`slide-breadcrumbs title-style-${first?.titleStyle || 'breadcrumb'}${first?.titleBackground ? ' boxed' : ''}`}
      style={first?.titleBackground
        ? `--title-bg: ${first.titleBackground}; --title-color: ${first.titleColor || '#fff'};`
        : ''}
    >
      <div class="breadcrumbs">
        {first && renderCrumbs(first.crumbs).map((crumb, i) => (
          <>
            {i > 0 && <span class="crumb-sep"> &rsaquo; </span>}
            {crumb.href
              ? <a href={crumb.href}>{crumb.label}</a>
              : <span>{crumb.label}</span>}
          </>
        ))}
      </div>
    </div>

    <button class="slide-arrow prev" id="slide-prev" aria-label="Previous">&lt;</button>
    <button class="slide-arrow next" id="slide-next" aria-label="Next">&gt;</button>
  </div>
</div>

<script>
  (function () {
    const showEl = document.getElementById('slideshow');
    if (!showEl) return;
    const slides = showEl.querySelectorAll('.slide');
    const prevBtn = document.getElementById('slide-prev');
    const nextBtn = document.getElementById('slide-next');
    const overlay = showEl.querySelector('.slide-breadcrumbs') as HTMLElement | null;
    const crumbsEl = overlay?.querySelector('.breadcrumbs') as HTMLElement | null;
    if (!slides.length) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval>;
    let isAnimating = false;
    let wasDrag = false;

    type Crumb = { label: string; href?: string };

    /* Rebuild the breadcrumb overlay from the active slide's crumbs, and apply
       the per-slide boxed style (custom colors) when present. */
    function updateBreadcrumb() {
      const el = slides[current] as HTMLElement;
      if (!overlay || !crumbsEl) return;

      let crumbs: Crumb[] = [];
      try {
        crumbs = JSON.parse(el.dataset.crumbs || '[]');
      } catch {
        crumbs = [];
      }

      // Rebuild the inner trail.
      crumbsEl.innerHTML = '';
      crumbs.forEach((crumb, i) => {
        if (i > 0) {
          const sep = document.createElement('span');
          sep.className = 'crumb-sep';
          sep.innerHTML = ' &rsaquo; ';
          crumbsEl.appendChild(sep);
        }
        if (crumb.href) {
          const a = document.createElement('a');
          a.href = crumb.href;
          a.textContent = crumb.label;
          crumbsEl.appendChild(a);
        } else {
          const span = document.createElement('span');
          span.textContent = crumb.label;
          crumbsEl.appendChild(span);
        }
      });

      // Per-slide text style (breadcrumb vs label).
      overlay.classList.remove('title-style-breadcrumb', 'title-style-label');
      overlay.classList.add('title-style-' + (el.dataset.titleStyle || 'breadcrumb'));

      // Boxed vs text-only.
      const bg = el.dataset.titleBg || '';
      const color = el.dataset.titleColor || '';
      if (bg) {
        overlay.classList.add('boxed');
        overlay.style.setProperty('--title-bg', bg);
        overlay.style.setProperty('--title-color', color || '#fff');
      } else {
        overlay.classList.remove('boxed');
        overlay.style.removeProperty('--title-bg');
        overlay.style.removeProperty('--title-color');
      }
    }

    /* Menu color + nav/title/breadcrumb glow. */
    function updateMenuColor() {
      const el = slides[current] as HTMLElement;
      const color = el.dataset.menuColor || 'white';
      document.body.classList.remove('menu-white', 'menu-black');
      document.body.classList.add('menu-' + color);

      const shadowColor = el.dataset.shadowColor || '';
      const glow = shadowColor
        ? `0 0 10px ${shadowColor}, 0 0 20px ${shadowColor}, 0 0 40px ${shadowColor}, 0 0 80px ${shadowColor}`
        : '';

      const siteTitle = document.querySelector('.site-title') as HTMLElement;
      if (siteTitle) { siteTitle.style.textShadow = glow; }

      const navLinks = document.querySelectorAll('.nav-menu > li > a');
      navLinks.forEach((link) => {
        (link as HTMLElement).style.textShadow = glow;
      });

      updateBreadcrumb();

      // Apply glow to the (rebuilt) breadcrumb pieces, but only when NOT boxed.
      if (overlay && !overlay.classList.contains('boxed')) {
        const crumbs = overlay.querySelectorAll('.breadcrumbs, .breadcrumbs a, .breadcrumbs span');
        crumbs.forEach((c) => { (c as HTMLElement).style.textShadow = glow; });
      } else if (overlay) {
        const crumbs = overlay.querySelectorAll('.breadcrumbs, .breadcrumbs a, .breadcrumbs span');
        crumbs.forEach((c) => { (c as HTMLElement).style.textShadow = ''; });
      }
    }

    /* Auto-advance timer */
    function startTimer() {
      clearInterval(timer);
      timer = setInterval(() => { activateOpacity(current + 1); }, 5000);
    }

    /* Opacity-based activation */
    function activateOpacity(n: number) {
      if (isAnimating) return;
      slides[current].classList.remove('active');
      current = ((n % slides.length) + slides.length) % slides.length;
      slides[current].classList.add('active');
      updateMenuColor();
    }

    /* Arrow buttons */
    prevBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      activateOpacity(current - 1);
      startTimer();
    });
    nextBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      activateOpacity(current + 1);
      startTimer();
    });

    /* Physical keyboard arrows: change slide + reset timer */
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') {
        activateOpacity(current - 1);
        startTimer();
      } else if (e.key === 'ArrowRight') {
        activateOpacity(current + 1);
        startTimer();
      }
    });

    /* Click to navigate */
    slides.forEach((slide) => {
      slide.addEventListener('click', function (this: HTMLElement) {
        if (!wasDrag) {
          const link = this.dataset.link;
          if (link) window.location.href = link;
        }
      });
    });

    /* Touch handling for swipe */
    let touchStartX = 0;
    let touchStartY = 0;
    let isDragging = false;
    let adjIdx = -1;

    function cleanupDrag() {
      adjIdx = -1;
      slides.forEach((slide) => {
        const el = slide as HTMLElement;
        el.style.transition = 'none';
        el.style.transform = '';
        el.style.opacity = slide.classList.contains('active') ? '1' : '0';
      });
      requestAnimationFrame(() => {
        slides.forEach((slide) => {
          const el = slide as HTMLElement;
          el.style.transition = '';
          el.style.opacity = '';
        });
      });
    }

    function commitToSlide(newIdx: number) {
      slides[current].classList.remove('active');
      current = newIdx;
      slides[current].classList.add('active');
      updateMenuColor();
      cleanupDrag();
      isAnimating = false;
    }

    showEl.addEventListener('touchstart', (e) => {
      if ((e.target as HTMLElement).closest('.slide-arrow')) return;
      if (e.changedTouches.length !== 1 || isAnimating) return;
      touchStartX = e.changedTouches[0].screenX;
      touchStartY = e.changedTouches[0].screenY;
      isDragging = false;
      wasDrag = false;
      adjIdx = -1;
      /* Pause auto-advance while a finger is on the screen */
      clearInterval(timer);
    }, { passive: true });

    showEl.addEventListener('touchmove', (e) => {
      if (e.changedTouches.length !== 1 || isAnimating) return;
      const dx = e.changedTouches[0].screenX - touchStartX;
      const dy = e.changedTouches[0].screenY - touchStartY;

      if (!isDragging) {
        if (Math.abs(dx) < 8) return;
        if (Math.abs(dy) > Math.abs(dx)) return;
        isDragging = true;
        wasDrag = true;

        const w = showEl.offsetWidth;
        adjIdx = dx < 0
          ? (current + 1) % slides.length
          : (current - 1 + slides.length) % slides.length;

        (slides[current] as HTMLElement).style.transition = 'none';
        (slides[adjIdx] as HTMLElement).style.transition = 'none';
        (slides[adjIdx] as HTMLElement).style.opacity = '1';
        (slides[adjIdx] as HTMLElement).style.transform = dx < 0
          ? `translateX(${w}px)`
          : `translateX(-${w}px)`;
      }

      const w = showEl.offsetWidth;
      (slides[current] as HTMLElement).style.transform = `translateX(${dx}px)`;
      (slides[adjIdx] as HTMLElement).style.transform = dx < 0
        ? `translateX(${w + dx}px)`
        : `translateX(${-w + dx}px)`;
    }, { passive: true });

    showEl.addEventListener('touchcancel', () => {
      /* Finger lifted/cancelled without a drag: restart the countdown */
      if (!isDragging && !isAnimating) startTimer();
    }, { passive: true });

    showEl.addEventListener('touchend', (e) => {
      if (e.changedTouches.length !== 1) return;
      if (!isDragging) {
        /* A tap/hold with no drag: resume the timer from release */
        if (!isAnimating) startTimer();
        return;
      }

      const dx = e.changedTouches[0].screenX - touchStartX;
      const w = showEl.offsetWidth;
      const fromIdx = current;
      const toIdx = adjIdx;
      const SNAP = 'transform 0.3s ease';
      const BACK = 'transform 0.2s ease';
      const isToNext = toIdx === (fromIdx + 1) % slides.length;

      isAnimating = true;

      if (Math.abs(dx) > 50 && toIdx >= 0) {
        /* Commit swipe */
        (slides[fromIdx] as HTMLElement).style.transition = SNAP;
        (slides[toIdx] as HTMLElement).style.transition = SNAP;
        (slides[fromIdx] as HTMLElement).style.transform = isToNext
          ? `translateX(-${w}px)`
          : `translateX(${w}px)`;
        (slides[toIdx] as HTMLElement).style.transform = 'translateX(0)';

        slides[toIdx].addEventListener('transitionend', function onEnd(ev) {
          if ((ev as TransitionEvent).propertyName !== 'transform') return;
          slides[toIdx].removeEventListener('transitionend', onEnd as EventListener);
          commitToSlide(toIdx);
          startTimer();
        });
      } else {
        /* Snap back */
        (slides[fromIdx] as HTMLElement).style.transition = BACK;
        (slides[fromIdx] as HTMLElement).style.transform = 'translateX(0)';
        if (toIdx >= 0) {
          (slides[toIdx] as HTMLElement).style.transition = BACK;
          (slides[toIdx] as HTMLElement).style.transform = isToNext
            ? `translateX(${w}px)`
            : `translateX(-${w}px)`;
        }

        slides[fromIdx].addEventListener('transitionend', function onEnd(ev) {
          if ((ev as TransitionEvent).propertyName !== 'transform') return;
          slides[fromIdx].removeEventListener('transitionend', onEnd as EventListener);
          cleanupDrag();
          isAnimating = false;
          startTimer();
        });
      }
    }, { passive: true });

    /* Init */
    updateMenuColor();
    startTimer();
  })();
</script>
