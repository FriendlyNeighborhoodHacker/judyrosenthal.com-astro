---
import { Image } from 'astro:assets';

interface Props {
  src: string;
  alt?: string;
  float?: 'left' | 'right' | 'center';
  link?: string;
}

const { src, alt = '', float = 'right', link } = Astro.props;

// Import the image
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/**/*.{jpeg,jpg,png,gif}');
const imagePath = `/src/assets/${src}`;
const imageModule = images[imagePath];

if (!imageModule) {
  console.warn(`Image not found: ${imagePath}`);
}

const isExternal = link?.startsWith('http');
---

{imageModule && (
  <figure class={`bio-figure bio-${float}`}>
    {link ? (
      <a href={link} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener noreferrer' : undefined}>
        <Image src={imageModule()} alt={alt} width={600} />
      </a>
    ) : (
      <Image src={imageModule()} alt={alt} width={600} />
    )}
  </figure>
)}
